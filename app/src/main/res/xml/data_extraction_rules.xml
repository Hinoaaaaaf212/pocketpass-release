<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="."/>
        <exclude domain="file" path="datastore/pocketpass_prefs.preferences_pb"/>
        <exclude domain="database" path="pocketpass_database"/>
        <exclude domain="database" path="pocketpass_database-wal"/>
        <exclude domain="database" path="pocketpass_database-shm"/>
        <exclude domain="sharedpref" path="."/>
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="."/>
        <exclude domain="file" path="datastore/pocketpass_prefs.preferences_pb"/>
        <exclude domain="database" path="pocketpass_database"/>
        <exclude domain="database" path="pocketpass_database-wal"/>
        <exclude domain="database" path="pocketpass_database-shm"/>
        <exclude domain="sharedpref" path="."/>
    </device-transfer>
</data-extraction-rules>
